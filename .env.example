# Database
DATABASE_URL=postgresql+psycopg://pehel:password@localhost:5432/pehel_neo

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=your_secret_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# AI
GROQ_API_KEY=your_groq_api_key_here

# MinIO / S3
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=pehel-media
S3_REGION=us-east-1

# App
ENVIRONMENT=development
DEBUG=false
CORS_ORIGINS=http://localhost:3000

# Pilot
PILOT_CITY=Kanpur
PILOT_STATE=Uttar Pradesh

# Mock OTP (hackathon/demo mode)
MOCK_OTP=true
DEFAULT_MOCK_OTP=123456

# Duplicate/presence detection (meters)
PRESENCE_CHECK_BUFFER_METERS=200
DUPLICATE_RADIUS_METERS=150
REPEAT_FAILURE_RADIUS_METERS=80